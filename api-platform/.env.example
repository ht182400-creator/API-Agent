# ============================================
# API Platform 环境配置文件
# 复制此文件为 .env 并修改相应值
# ============================================

# ============================================
# 环境模式
# development: 开发环境 (详细日志)
# test: 测试环境 (信息日志)
# production: 生产环境 (警告以上)
# ============================================
ENVIRONMENT=development

# ============================================
# 日志配置
# 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: 记录所有日志 (开发环境推荐)
# INFO: 记录一般信息 (测试环境推荐)
# WARNING: 仅警告和错误 (生产环境推荐)
# ERROR: 仅错误
# CRITICAL: 仅严重错误
# ============================================
LOG_LEVEL=DEBUG
LOG_FILE=logs/api_platform.log
LOG_ENABLE_CONSOLE=true
LOG_ENABLE_FILE=true
LOG_ROTATION=size  # size: 按大小轮转, time: 按时间轮转

# ============================================
# 日志备份配置
# ============================================
LOG_BACKUP_MAX_SIZE_MB=10      # 单个日志文件最大大小(MB)
LOG_BACKUP_MAX_FILES=100       # 最大备份文件数量
LOG_BACKUP_AUTO_CLEANUP=true   # 是否自动清理旧备份
LOG_BACKUP_CLEANUP_THRESHOLD=80 # 清理阈值(%)
LOG_BACKUP_ENABLED=true        # 是否启用自动备份

# ============================================
# 数据库配置
# ============================================
DATABASE_URL=postgresql+asyncpg://api_user:api_password@localhost:5432/api_platform

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://:password@localhost:6379/0

# ============================================
# JWT 配置
# ============================================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# API 配置
# ============================================
API_V1_PREFIX=/api/v1
DEBUG=true

# ============================================
# CORS 配置 (逗号分隔)
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================
# 安全配置
# ============================================
SECRET_KEY=your-application-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-32-bytes

# ============================================
# 速率限制
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
