# API 平台前端环境变量配置
# 复制此文件为 .env.local 并修改相应配置

# ============ API 配置 ============
# API 基础地址
VITE_API_URL=/api/v1

# ============ 日志配置 ============
# 日志级别: debug | info | warn | error
# 开发环境默认 debug，生产环境默认 info
VITE_LOG_LEVEL=debug

# 最大日志条数
VITE_LOG_MAX_SIZE=500

# 是否输出到控制台
VITE_LOG_ENABLE_CONSOLE=true

# 是否保存到本地存储
VITE_LOG_ENABLE_STORAGE=true

# 是否上报到服务器
VITE_LOG_ENABLE_REMOTE=false

# 日志上报地址
VITE_LOG_REMOTE_URL=/api/v1/logs/frontend

# ============ 功能开关 ============
# 是否启用调试模式
VITE_DEBUG=false

# 是否启用性能监控
VITE_PERFORMANCE_MONITOR=false

# 是否启用错误上报
VITE_ERROR_REPORT=true
