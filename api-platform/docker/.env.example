# ==================== 应用配置 ====================
APP_NAME=API Platform
APP_ENV=production
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# ==================== 数据库配置 ====================
POSTGRES_DB=api_platform
POSTGRES_USER=api_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://api_user:your_secure_password@postgres:5432/api_platform

# ==================== Redis配置 ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_password
REDIS_DB=0
REDIS_URL=redis://:your_secure_password@redis:6379/0

# ==================== MinIO配置 ====================
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=api-platform
MINIO_REGION=cn-north-1

# ==================== 前端配置 ====================
VITE_API_URL=/api
VITE_APP_TITLE=API Platform

# ==================== CORS配置 ====================
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# ==================== 端口配置 ====================
FRONTEND_PORT=80
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ==================== 版本配置 ====================
VERSION=latest

# ==================== 构建环境 ====================
BUILD_ENV=production

# ==================== Grafana配置 ====================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ==================== 时区配置 ====================
TZ=Asia/Shanghai
